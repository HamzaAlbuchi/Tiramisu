# Dev: leave unset to use Vite proxy (/api → http://localhost:8080).
#
# Production / Railway: REQUIRED. Without it, /api/debate hits the SPA server and returns HTML → JSON parse error.
# Example: VITE_API_BASE_URL=https://your-api-service.up.railway.app
# Railway: set Variable on the *frontend* service and redeploy (value is baked in at build time).
# VITE_API_BASE_URL=
